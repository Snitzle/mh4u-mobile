# Copy to .env.local and tweak for your device:  cp .env.example .env.local
#
# The default below works for the iOS simulator, which shares the host's
# localhost. For a physical device (Expo Go over Wi-Fi), set this to your
# machine's LAN address, e.g. http://192.168.1.50:8088/api/v1
EXPO_PUBLIC_API_BASE=http://localhost:8088/api/v1
